# ── Application ───────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-before-production

# ── NewsAPI ───────────────────────────────────────────────────
# Get a free key from https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_API_TIMEOUT=10
NEWS_API_MAX_RETRIES=3

# ── Redis (Phase 3) ───────────────────────────────────────────
# Set USE_REDIS=true when Redis is running locally or via docker-compose
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0

# ── Database (Phase 3) ────────────────────────────────────────
# Uncomment and fill when PostgreSQL is running (docker-compose spins it up)
# DATABASE_URL=postgresql://hubb:hubb_local_password@localhost:5432/hubb_db

# ── ML Model ──────────────────────────────────────────────────
MODEL_NAME=sshleifer/distilbart-cnn-12-6
MODEL_VERSION=sshleifer/distilbart-cnn-12-6

# ── Celery (Phase 3) ──────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Observability (Phase 4) ───────────────────────────────────
OTEL_SERVICE_NAME=hubb-api
OTEL_SERVICE_VERSION=1.0.0
# OTLP endpoint — set to send traces to Jaeger / Grafana Tempo / any OTLP collector
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Security ──────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
ALLOWED_ORIGINS=*
